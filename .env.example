# Copy this file to .env and fill values.
# The API auto-loads .env at startup.

# Required for optional French -> English model translation
GROQ_API_KEY=your_groq_api_key_here

# Optional translation controls
OFF_TRANSLATION_PROVIDER=groq
OFF_TRANSLATION_MODEL=llama-3.1-8b-instant
OFF_TRANSLATION_TIMEOUT_S=8
